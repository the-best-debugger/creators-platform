        {
          "name": "Create Post",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"CreatePost: status 200 or 201\", () => pm.expect(pm.response.code).to.be.oneOf([200,201]));\r",
                  "\r",
                  "let json;\r",
                  "try { json = pm.response.json(); } catch (e) { json = {}; }\r",
                  "\r",
                  "pm.test(\"CreatePost: success true\", () => {\r",
                  "  pm.expect(json).to.have.property('success');\r",
                  "  pm.expect(json.success).to.be.true;\r",
                  "});\r",
                  "\r",
                  "// Extract created post object (support common shapes)\r",
                  "const created = json.data ?? json.post ?? json;\r",
                  "const postObj = created?.data ?? created;\r",
                  "const id = postObj?._id ?? postObj?.id ?? null;\r",
                  "\r",
                  "pm.test(\"CreatePost: created id exists\", () => pm.expect(id).to.be.ok);\r",
                  "if (id) pm.environment.set(\"createdPostId\", id);\r",
                  "\r",
                  "pm.test(\"CreatePost: has title and content\", () => {\r",
                  "  pm.expect(postObj).to.have.property('title');\r",
                  "  pm.expect(postObj).to.have.property('content');\r",
                  "});\r",
                  "\r",
                  "// Optional: check returned title matches request\r",
                  "try {\r",
                  "  const reqTitle = pm.request.body && JSON.parse(pm.request.body.raw).title;\r",
                  "  if (reqTitle !== undefined) pm.test(\"Title matches request\", () => pm.expect(postObj?.title).to.eql(reqTitle));\r",
                  "} catch (e) { /* ignore parse errors */ }"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
